server {
    listen {{ .SubscribePort }} ssl;
    http2 on;
    server_name {{ .Domain }};

    ssl_certificate {{ .CertificatePath }};
    ssl_certificate_key {{ .KeyPath }};

    root {{ .WebRoot }};

    location /s/ {
        alias {{ .SubscribeDir }}/;
        default_type text/plain;
        charset utf-8;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

{{ if .EnableMonitor }}server {
    listen {{ .MonitorPublicPort }} ssl;
    http2 on;
    server_name {{ .Domain }};

    ssl_certificate {{ .CertificatePath }};
    ssl_certificate_key {{ .KeyPath }};

    location = / {
        return 302 /monitor/;
    }

    location /monitor/ {
        proxy_pass http://127.0.0.1:{{ .MonitorPort }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /monitor/api/ {
        proxy_pass http://127.0.0.1:{{ .MonitorPort }}/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
{{ end }}
