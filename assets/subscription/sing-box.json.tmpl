      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "Telegram",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
{{- if .OutboundsJSON }}
    {{ .OutboundsJSON }},
{{- end }}
    {
      "type": "direct",
      "tag": "DIRECT"
    }
  ],
