    "rules": [
      {"rule_set": "Lan", "outbound": "本地直连"},
      {"rule_set": ["OpenAI", "Gemini", "Claude", "Copilot", "Anthropic"], "outbound": "AI服务"},
      {"domain_suffix": "openrouter.ai", "outbound": "AI服务"},
      {"rule_set": "Spotify", "outbound": "Spotify"},
      {"rule_set": ["Epic", "Origin", "Sony", "Steam", "Nintendo"], "outbound": "游戏平台"},
      {"rule_set": ["HBO", "Hulu", "Disney", "TikTok", "YouTube", "Netflix", "Threads", "Instagram"], "outbound": "国外媒体"},
      {"rule_set": "ChinaMedia", "outbound": "国内媒体"},
      {"rule_set": "Scholar", "outbound": "学术网页"},
      {"rule_set": ["Bing", "Microsoft", "OneDrive"], "outbound": "Microsoft"},
      {"rule_set": "Apple", "outbound": "Apple"},
      {"rule_set": "Google", "outbound": "Google"},
      {"rule_set": "GitHub", "outbound": "GitHub"},
      {"rule_set": "Telegram", "outbound": "Telegram"},
      {"rule_set": "Proxy", "outbound": "全球代理"},
      {"rule_set": "Direct", "outbound": "本地直连"},
      {"rule_set": ["ChinaMaxNoMedia", "ChinaIPs"], "outbound": "本地直连"}
    ],
    "default_domain_resolver": {
      "server": "local",
      "strategy": "prefer_ipv4"
    },
    "default_http_client": "proxy-http",
    "final": "漏网之鱼",
    "auto_detect_interface": true
  }
}
