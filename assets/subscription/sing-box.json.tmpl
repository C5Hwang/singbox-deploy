{
  "http_clients": [
    {
      "tag": "proxy-http",
      "detour": "DIRECT"
    }
  ],
  "log": {
    "level": "debug",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "https",
        "tag": "cloudflare",
        "server": "1.1.1.1",
        "detour": "全球代理"
      },
      {
        "type": "https",
        "tag": "google",
        "server": "8.8.8.8",
        "detour": "全球代理"
      },
      {
        "type": "https",
        "tag": "dnspod",
        "server": "1.12.12.12",
        "tls": {
          "server_name": "doh.pub"
        },
        "detour": "DIRECT"
      },
      {
        "type": "https",
        "tag": "alidns",
        "server": "223.5.5.5",
        "tls": {
          "server_name": "dns.alidns.com"
        },
        "detour": "DIRECT"
      },
      {
        "type": "local",
        "tag": "local"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "198.18.0.0/16"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          ".lan",
          ".local"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "domain": [
          "dns.google",
          "localhost.ptlogin2.qq.com"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "rule_set": "Lan",
        "action": "route",
        "server": "local"
      },
      {
        "rule_set": "ChinaMaxNoIP",
        "action": "route",
        "server": "alidns"
      }
    ],
    "final": "fakeip",
    "strategy": "prefer_ipv4",
    "reverse_mapping": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.18.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed",
      "sniff": true,
      "sniff_override_destination": false
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "0.0.0.0",
      "listen_port": 7890,
      "sniff": true,
      "sniff_override_destination": false
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "🚀 手动切换",
      "outbounds": {{ .ProxyTagsJSON }},
      "default": {{ .DefaultProxyTag | json }}
    },
    {
      "type": "urltest",
      "tag": "♻️ 自动选择",
      "outbounds": {{ .ProxyTagsJSON }},
      "url": "http://www.gstatic.com/generate_204",
      "interval": "10h",
      "tolerance": 50
    },
{{- range .Countries }}
    {
      "type": "urltest",
      "tag": {{ .Tag | json }},
      "outbounds": {{ .TagsJSON }},
      "url": "http://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
{{- end }}
    {
      "type": "selector",
      "tag": "全球代理",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "国外媒体",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "国内媒体",
      "outbounds": ["DIRECT", "🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}],
      "default": "DIRECT"
    },
    {
      "type": "selector",
      "tag": "AI服务",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "游戏平台",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "学术网页",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "本地直连",
      "outbounds": ["DIRECT", "🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}],
      "default": "DIRECT"
    },
    {
      "type": "selector",
      "tag": "漏网之鱼",
      "outbounds": ["🚀 手动切换", "DIRECT", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "Google",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
    },
    {
      "type": "selector",
      "tag": "Microsoft",
      "outbounds": ["DIRECT", "🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}],
      "default": "DIRECT"
    },
    {
      "type": "selector",
      "tag": "Apple",
      "outbounds": ["DIRECT", "🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}],
      "default": "DIRECT"
    },
    {
      "type": "selector",
      "tag": "GitHub",
      "outbounds": ["🚀 手动切换", "♻️ 自动选择"{{- range .Countries }}, {{ .Tag | json }}{{- end }}, "DIRECT"],
      "default": "🚀 手动切换"
