<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
    body { margin: 0; font-family: system-ui, sans-serif; color: #172033; background: linear-gradient(135deg, #f8fbff, #e9f0ff); }
    main { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
    section { max-width: 760px; padding: 3rem; background: rgba(255,255,255,.82); border: 1px solid rgba(80,110,160,.18); border-radius: 28px; box-shadow: 0 24px 70px rgba(35,60,120,.12); }
    h1 { font-size: clamp(2.2rem, 7vw, 5rem); line-height: .95; margin: 0 0 1rem; }
    p { font-size: 1.15rem; line-height: 1.7; margin: 0; color: #43506a; }
  </style>
</head>
<body>
  <main>
    <section>
      <h1>{{ .Title }}</h1>
      <p>{{ .Subtitle }}</p>
    </section>
  </main>
</body>
</html>
