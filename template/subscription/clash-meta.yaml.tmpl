mixed-port: 7890
allow-lan: true
mode: rule
log-level: info
ipv6: true
external-controller: 127.0.0.1:9090

profile:
  store-selected: true
  store-fake-ip: true

dns:
  enable: true
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

proxies:
{{ .ProxiesYAML }}

proxy-groups:
  - name: PROXY
    type: select
    proxies:
{{ .ProxyNamesYAML }}

rules:
  - GEOIP,CN,DIRECT
  - MATCH,PROXY
